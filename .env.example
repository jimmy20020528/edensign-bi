# ── OpenAI ──
OPENAI_API_KEY=sk-...

# ── Google (Gemini VLM) ──
GEMINI_API_KEY=...

# ── RunPod (staging AI) ──
RUNPOD_API_KEY=...
RUNPOD_STAGING_ENDPOINT=...

# ── PostgreSQL ──
DB_USER=edensign
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edensign_bi

# ── External data APIs ──
WALKSCORE_API_KEY=...
# Optional outbound proxy for the key-free public sources ONLY (OSM Nominatim,
# Overpass, Walk Score, NCES, Redfin) — they rate-limit/block datacenter IPs.
# e.g. http://user:pass@host:port  — OpenAI/Gemini/internal calls never use it.
PUBLIC_DATA_PROXY=
# Optional amenities fallbacks, used only when every Overpass mirror fails.
# Both free tiers (Geoapify 3000/day, LocationIQ 5000/day), OSM-backed data.
GEOAPIFY_API_KEY=
LOCATIONIQ_API_KEY=
GOOGLE_MAPS_API_KEY=...
GREATSCHOOLS_API_KEY=...
CENSUS_API_KEY=...
RENTCAST_API_KEY=...
FRED_API_KEY=...

# ── AWS S3 (photo upload CDN) ──
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# ── Supabase (wizard submissions DB) ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# ── Service base URLs (used by agent) ──
BI_BASE=http://localhost:8000
HOME_REPORT_BASE=http://localhost:8001
CV_MODELS_BASE=http://localhost:8003
