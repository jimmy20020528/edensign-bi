# OpenAI — explanation + LLM market estimator (fallback for ZIPs with no local data)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini                  # used by /explain endpoint
OPENAI_MODEL_ESTIMATOR=gpt-4o             # used by LLM fallback (needs stronger reasoning)
# OPENAI_BASE_URL=https://api.openai.com/v1
# ══════════════════════════════════════════════
# Edensign BI — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# ── PostgreSQL + PostGIS ──
# 本地开发用 Docker container，production 用 AWS RDS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edensign_bi
DB_USER=edensign
# 须与正在连接的 Postgres 一致。用本项目 docker-compose 时等于 POSTGRES_PASSWORD（默认 edensign_dev）
DB_PASSWORD=edensign_dev

# ── US Census ACS API ──
# 免费申请: https://api.census.gov/data/key_signup.html
# 没有key也能用(50 calls/day), 有key 2000 calls/day
CENSUS_API_KEY=your_census_key_here

# ── RentCast API ──
# 免费注册: https://www.rentcast.io/api
# 免费 50 calls/month, 付费 $29+/mo
RENTCAST_API_KEY=your_rentcast_key_here

# ── Walk Score API ──
# 申请: https://www.walkscore.com/professional/api-sign-up.php
# 免费 5000 calls/day
WALKSCORE_API_KEY=your_walkscore_key_here

# ── Google Maps / Places API ──
# Console: https://console.cloud.google.com/
# $200/month free credit
GOOGLE_MAPS_API_KEY=your_google_key_here

# ── GreatSchools API ──
# 申请: https://www.greatschools.org/api/request-a-key
GREATSCHOOLS_API_KEY=your_greatschools_key_here

# ── FRED API (Federal Reserve Economic Data) ──
# 免费申请: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# ── Edensign VLM (RunPod) ──
# 用现有的 RunPod endpoint
RUNPOD_API_KEY=your_runpod_key_here
RUNPOD_VLM_ENDPOINT=your_endpoint_id_here

# ── Google Gemini API ──
# Google AI Studio 申请: https://aistudio.google.com/app/apikey
# Step 4 用 2.5 Pro 做房屋 staging 风格分类
GEMINI_API_KEY=your_gemini_key_here
